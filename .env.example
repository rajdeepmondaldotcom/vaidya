# ============================================================
# Vaidya Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# -----------------------------------------------------------
# REQUIRED: Sarvam AI API Key
# Get yours free at: https://dashboard.sarvam.ai
# Sign up → Dashboard → API Keys → Create Key (starts with sk_)
# Free tier includes: LLM (sarvam-105b/30b), STT, TTS, Translation
# -----------------------------------------------------------
SARVAM_API_KEY=your_sarvam_api_key_here

# -----------------------------------------------------------
# Redis (session state management)
# Default: localhost. Docker compose provides this automatically.
# -----------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------
# ChromaDB (knowledge store for scheme retrieval)
# Default: local directory. Docker compose provides this.
# -----------------------------------------------------------
CHROMADB_PATH=./chroma_data

# -----------------------------------------------------------
# Server
# -----------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# -----------------------------------------------------------
# Logging
# -----------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------
# Environment (development enables auto-reload)
# -----------------------------------------------------------
ENVIRONMENT=development

# -----------------------------------------------------------
# Model routing (optional — defaults are production-optimized)
# sarvam-105b: flagship, 128K context, complex reasoning
# sarvam-30b: efficient, 64K context, simple tasks
# Both are FREE on Sarvam's current pricing
# -----------------------------------------------------------
# ORCHESTRATOR_MODEL=sarvam-30b
# INTAKE_MODEL=sarvam-30b
# ELIGIBILITY_MODEL=sarvam-105b
# REVIEWER_MODEL=sarvam-105b
# GUIDANCE_MODEL=sarvam-30b
