# ============================================================
# Vaidya Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# -----------------------------------------------------------
# REQUIRED: Sarvam AI API Key
# Get yours free at: https://dashboard.sarvam.ai
# Sign up → Dashboard → API Keys → Create Key (starts with sk_)
# Free tier includes: LLM (sarvam-105b/30b), STT, TTS, Translation
# -----------------------------------------------------------
SARVAM_API_KEY=your_sarvam_api_key_here

# -----------------------------------------------------------
# Redis (session state management)
# Default: localhost. Docker compose provides this automatically.
# -----------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------
# ChromaDB (knowledge store for scheme retrieval)
# Default: local directory. Docker compose provides this.
# -----------------------------------------------------------
CHROMADB_PATH=./chroma_data

# -----------------------------------------------------------
# Server
# -----------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# -----------------------------------------------------------
# Logging
# -----------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------
# Environment (development enables auto-reload)
# -----------------------------------------------------------
ENVIRONMENT=development

# -----------------------------------------------------------
# Model routing (optional — these ARE the defaults)
# sarvam-105b: flagship, 128K context, complex reasoning
# sarvam-30b: efficient, 64K context, ~3x faster, simple tasks
# Both are FREE on Sarvam's current pricing
# Default: 30b for intake/orchestrator/guidance, 105b for eligibility/reviewer
# -----------------------------------------------------------
# ORCHESTRATOR_MODEL=sarvam-30b
# INTAKE_MODEL=sarvam-30b
# ELIGIBILITY_MODEL=sarvam-105b
# REVIEWER_MODEL=sarvam-105b
# GUIDANCE_MODEL=sarvam-30b

# -----------------------------------------------------------
# Advanced LLM settings (optional)
# reasoning_effort: low/medium/high (controls thinking depth)
# wiki_grounding: true/false (grounds in Wikipedia for facts)
# -----------------------------------------------------------
# ELIGIBILITY_REASONING_EFFORT=high
# REVIEWER_REASONING_EFFORT=high
# INTAKE_REASONING_EFFORT=low
# GUIDANCE_REASONING_EFFORT=low
# WIKI_GROUNDING=true

# -----------------------------------------------------------
# TTS settings (optional)
# -----------------------------------------------------------
# TTS_SAMPLE_RATE=8000
# TTS_DEFAULT_PACE=1.0
# TTS_DISTRESS_PACE=0.85

# -----------------------------------------------------------
# STT settings (optional)
# -----------------------------------------------------------
# STT_MODEL=saaras:v3
# STT_MODE=transcribe

# -----------------------------------------------------------
# Telephony (Twilio)
# Sign up free at https://www.twilio.com/try-twilio
# -----------------------------------------------------------
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
# VOICE_WEBSOCKET_URL=wss://your-server.up.railway.app/voice/stream
# VOICE_STATUS_CALLBACK_URL=https://your-server.up.railway.app/voice/status
